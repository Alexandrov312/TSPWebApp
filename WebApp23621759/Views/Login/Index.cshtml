@model WebApp23621759.Models.ViewModel.Auth.LoginUserViewModel

<div class="page-auth">
    <div class="card-auth">
        <h2 class="title">Login</h2>

        <form asp-action="Index" asp-controller="Login" method="post" class="auth-form">
            <div class="form-group">
                <label asp-for="UsernameOrEmail">👤 Username / 📧 Email</label>
                <input asp-for="UsernameOrEmail" placeholder="Enter your username or email" />
                <div class="field-error">
                    <span asp-validation-for="UsernameOrEmail"></span>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Password">🔒 Password</label>
                <div class="password-peek-field" data-password-peek>
                    <input asp-for="Password" type="password" placeholder="Enter your password" />
                    <button type="button" class="password-peek-btn" data-password-peek-toggle aria-label="Show password">⌣</button>
                </div>
                <div class="field-error">
                    <span asp-validation-for="Password"></span>
                </div>
            </div>

            <div class="auth-inline-options">
                <label class="remember-me-option">
                    <input asp-for="RememberMe" type="checkbox" />
                    <span>Remember me</span>
                </label>
            </div>

            <div class="forgot-password">
                <a asp-controller="AccountSecurity" asp-action="ForgotPassword">Forgot password?</a>
            </div>

            <div class="message-box">
                @if (ViewBag.ErrorMessage != null)
                {
                    <div class="error-message">@ViewBag.ErrorMessage</div>
                }
            </div>

            <button type="submit" class="primary-btn">Login</button>

            <div class="signup-row">
                <span>Don't have an account?</span>
                <a href="/Register">Sign up</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
