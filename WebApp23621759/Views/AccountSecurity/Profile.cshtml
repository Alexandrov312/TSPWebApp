@model WebApp23621759.Models.ViewModel.Auth.AccountSettingsViewModel

@{
    ViewData["Title"] = "Account";
}

<div class="account-page">
    <div class="account-page-header">
        <div>
            <p class="account-page-eyebrow">PERSONAL SETTINGS</p>
            <h1>My Account</h1>
            <p class="account-page-description">Manage your username, email address and password from one place.</p>
        </div>
    </div>

    <div class="account-page-grid">
        <section class="account-card">
            <h2>Profile overview</h2>
            <div class="account-summary-item">
                <span>Current username</span>
                <strong>@Model.CurrentUsername</strong>
            </div>
            <div class="account-summary-item">
                <span>Current email</span>
                <strong>@Model.CurrentEmail</strong>
            </div>
            <p class="account-summary-note">Use the forms on the right to update your login information.</p>
        </section>

        <section class="account-card">
            <h2>Change username</h2>
            <form asp-action="UpdateUsername" asp-controller="AccountSecurity" method="post" class="account-form">
                <div class="form-group">
                    <label asp-for="NewUsername">New username</label>
                    <input asp-for="NewUsername" value="@Model.CurrentUsername" />
                </div>
                <button type="submit" class="primary-btn">Save username</button>
            </form>
        </section>

        <section class="account-card">
            <h2>Change email</h2>
            <form asp-action="UpdateEmail" asp-controller="AccountSecurity" method="post" class="account-form">
                <div class="form-group">
                    <label asp-for="NewEmail">New email</label>
                    <input asp-for="NewEmail" type="email" value="@Model.CurrentEmail" />
                </div>
                <button type="submit" class="primary-btn">Save email</button>
            </form>
        </section>

        <section class="account-card">
            <h2>Change password</h2>
            <form asp-action="UpdatePassword" asp-controller="AccountSecurity" method="post" class="account-form">
                <div class="form-group">
                    <label asp-for="CurrentPassword">Current password</label>
                    <div class="password-peek-field" data-password-peek>
                        <input asp-for="CurrentPassword" type="password" />
                        <button type="button" class="password-peek-btn" data-password-peek-toggle aria-label="Show password">⌣</button>
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="NewPassword">New password</label>
                    <div class="password-peek-field" data-password-peek>
                        <input asp-for="NewPassword" type="password" />
                        <button type="button" class="password-peek-btn" data-password-peek-toggle aria-label="Show password">⌣</button>
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="ConfirmNewPassword">Confirm new password</label>
                    <div class="password-peek-field" data-password-peek>
                        <input asp-for="ConfirmNewPassword" type="password" />
                        <button type="button" class="password-peek-btn" data-password-peek-toggle aria-label="Show password">⌣</button>
                    </div>
                </div>
                <button type="submit" class="primary-btn">Save password</button>
            </form>
        </section>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
