@model WebApp23621759.Models.ViewModel.Auth.ResetPasswordViewModel

<div class="page-auth">
    <div class="card-auth">
        <h2 class="title">Reset Password</h2>
        <p class="auth-description">
            Enter the code sent to <strong>@Model.Email</strong> and choose a new password.
        </p>

        <form asp-action="ResetPassword" asp-controller="AccountSecurity" method="post" class="auth-form">
            <input asp-for="UserId" type="hidden" />
            <input asp-for="Email" type="hidden" />

            <div class="message-box">
                @if (ViewBag.ErrorMessage != null)
                {
                    <div class="error-message">@ViewBag.ErrorMessage</div>
                }
            </div>

            <div class="form-group">
                <label asp-for="Code">🔐 Reset code</label>
                <input asp-for="Code" inputmode="numeric" maxlength="6" placeholder="Enter the 6-digit code" />
                <div class="field-error">
                    <span asp-validation-for="Code"></span>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="NewPassword">🔒 New password</label>
                <div class="password-peek-field" data-password-peek>
                    <input asp-for="NewPassword" type="password" placeholder="Enter your new password" />
                    <button type="button" class="password-peek-btn" data-password-peek-toggle aria-label="Show password">⌣</button>
                </div>
                <div class="field-error">
                    <span asp-validation-for="NewPassword"></span>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="ConfirmPassword">🔒 Confirm new password</label>
                <div class="password-peek-field" data-password-peek>
                    <input asp-for="ConfirmPassword" type="password" placeholder="Confirm your new password" />
                    <button type="button" class="password-peek-btn" data-password-peek-toggle aria-label="Show password">⌣</button>
                </div>
                <div class="field-error">
                    <span asp-validation-for="ConfirmPassword"></span>
                </div>
            </div>

            <button type="submit" class="primary-btn">Reset password</button>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
