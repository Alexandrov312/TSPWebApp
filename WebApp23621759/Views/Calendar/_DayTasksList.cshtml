@using WebApp23621759.Enums
@using WebApp23621759.Helpers
@model WebApp23621759.Models.ViewModel.Calendar.CalendarViewModel

@*
    Endpoint е URL адрес, който сочи към метод в контролера и позволява на клиента (браузър/JavaScript) 
    да изпрати заявка и да получи отговор (HTML или JSON).
*@
@* Контейнерът държи данни за текущия ден и endpoint-а за AJAX презареждане *@
<div class="calendar-day-tasks-content"
     data-day-tasks-endpoint="@Url.Action("DayTasksList", "Calendar", new { year = Model.Year, month = Model.Month, selectedDate = Model.SelectedDate.ToString("yyyy-MM-dd") })"
     data-selected-date="@Model.SelectedDate.ToString("yyyy-MM-dd")"
     data-year="@Model.Year"
     data-month="@Model.Month">

    <div class="day-tasks-list">
        @* Ако има задачи за избрания ден *@
        @if (Model.SelectedDayTasks.Any())
        {
            @foreach (var taskItem in Model.SelectedDayTasks)
            {
                var task = taskItem.Task;

                @* Карта за една задача *@
                <div class="day-task-card @StatusHelper.GetCalendarCardClass(task.Status)"
                     data-calendar-task-id="@task.Id">

                    @* Горна част: срок + приоритет *@
                    <div class="day-task-top">
                        <div class="day-task-time calendar-due-date-slot">
                            <button type="button" class="calendar-due-date-trigger">
                                Until: @task.DueDate.ToString("dd/MM/yyyy HH:mm")
                            </button>
                            <input type="datetime-local"
                                   class="form-input calendar-due-date-input"
                                   value="@task.DueDate.ToString("yyyy-MM-ddTHH:mm")" />
                        </div>

                        @* Inline редакция на приоритет *@
                        <div class="calendar-priority-slot">
                            <button type="button"
                                    class="priority-badge @PriorityHelper.GetCssClass(task.Priority) calendar-priority-trigger">
                                @task.Priority
                            </button>

                            <select class="form-input calendar-priority-select">
                                @foreach (Priority priority in Enum.GetValues(typeof(Priority)))
                                {
                                    if (priority == task.Priority)
                                    {
                                        <option value="@((int)priority)" selected>@priority</option>
                                    }
                                    else
                                    {
                                        <option value="@((int)priority)">@priority</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    @* Inline editable заглавие *@
                    <div class="day-task-title calendar-inline-editable"
                         data-calendar-field="title"
                         contenteditable="true"
                         spellcheck="false">
                        @task.Title
                    </div>

                    @* Прогрес бар на задачата (на база подзадачи) *@
                    <div class="calendar-task-progress-block">
                        <div class="task-progress" data-task-progress-id="@task.Id">
                            <div class="task-progress-bar">
                                <div class="task-progress-fill task-progress-fill-projected" style="width: @taskItem.ProjectedCompletionPercentage%;"></div>
                                <div class="task-progress-fill task-progress-fill-completed" style="width: @taskItem.CompletionPercentage%;"></div>
                            </div>
                            <div class="task-progress-text">
                                @taskItem.CompletionPercentage% (@taskItem.CompletedSubTaskCount/@taskItem.TotalSubTaskCount)
                            </div>
                        </div>
                    </div>

                    @* Footer: статус + действия *@
                    <div class="calendar-task-footer">
                        <div class="calendar-task-status-text @StatusHelper.GetCssClass(task.Status)">
                            @StatusHelper.GetDisplayName(task.Status)
                        </div>

                        <div class="calendar-task-actions">
                            <a asp-controller="MyTasks"
                               asp-action="Index"
                               asp-route-kanbanTaskId="@task.Id"
                               asp-route-source="calendar"
                               asp-route-returnUrl="@Url.Action("Index", "Calendar", new { year = Model.Year, month = Model.Month, selectedDate = Model.SelectedDate.ToString("yyyy-MM-dd") })"
                               class="option-btn option-btn-kanban"
                               title="Open Kanban">
                                🧩
                            </a>

                            <div class="archive-wrapper delete-wrapper @(task.Status == Status.Completed ? "archive-enabled" : "archive-disabled")">
                                <form asp-action="Archive" method="post" class="calendar-task-archive-form calendar-task-ajax-form">
                                    <input type="hidden" name="id" value="@task.Id" />
                                    <input type="hidden" name="year" value="@Model.Year" />
                                    <input type="hidden" name="month" value="@Model.Month" />
                                    <input type="hidden" name="selectedDate" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" />

                                    <button type="button"
                                            class="option-btn option-btn-archive @(task.Status == Status.Completed ? "show-popup" : "")"
                                            title="@(task.Status == Status.Completed ? "Archive task" : "Complete the task before archiving")"
                                    @(task.Status == Status.Completed ? "" : "disabled")>
                                        📦
                                    </button>

                                    <div class="delete-popup">
                                        <span>Archive task?</span>
                                        <div class="popup-actions">
                                            <button type="submit" class="popup-btn popup-btn-confirm">Yes</button>
                                            <button type="button" class="popup-btn popup-btn-cancel cancel-btn">No</button>
                                        </div>
                                    </div>
                                </form>
                            </div>

                            @* Маркиране като завършена *@
                            <div class="done-wrapper">
                                <form asp-action="MarkAsDone" method="post" class="calendar-task-done-form calendar-task-ajax-form">
                                    <input type="hidden" name="id" value="@task.Id" />
                                    <input type="hidden" name="year" value="@Model.Year" />
                                    <input type="hidden" name="month" value="@Model.Month" />
                                    <input type="hidden" name="selectedDate" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" />

                                    <button type="button" class="option-btn option-btn-success show-done-popup" title="Mark as done">✓</button>

                                    @* Popup за потвърждение *@
                                    <div class="done-popup">
                                        <span>Mark task as done?</span>
                                        <div class="popup-actions">
                                            <button type="submit" class="popup-btn popup-btn-confirm">Yes</button>
                                            <button type="button" class="popup-btn popup-btn-cancel cancel-done-btn">No</button>
                                        </div>
                                    </div>
                                </form>
                            </div>

                            @* Връщане към Pending за цялата задача и подзадачите ѝ *@
                            <div class="done-wrapper pending-wrapper">
                                <form asp-action="MarkAsPending" method="post" class="calendar-task-pending-form calendar-task-ajax-form">
                                    <input type="hidden" name="id" value="@task.Id" />
                                    <input type="hidden" name="year" value="@Model.Year" />
                                    <input type="hidden" name="month" value="@Model.Month" />
                                    <input type="hidden" name="selectedDate" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" />

                                    <button type="button" class="option-btn option-btn-neutral show-done-popup" title="Mark as pending">⟳</button>

                                    <div class="done-popup pending-popup">
                                        <span>Mark task as pending?</span>
                                        <div class="popup-actions">
                                            <button type="submit" class="popup-btn popup-btn-confirm">Yes</button>
                                            <button type="button" class="popup-btn popup-btn-cancel cancel-done-btn">No</button>
                                        </div>
                                    </div>
                                </form>
                            </div>

                            @* Изтриване на задача *@
                            <div class="delete-wrapper">
                                <form asp-action="Delete" method="post" class="calendar-task-delete-form calendar-task-ajax-form">
                                    <input type="hidden" name="id" value="@task.Id" />
                                    <input type="hidden" name="year" value="@Model.Year" />
                                    <input type="hidden" name="month" value="@Model.Month" />
                                    <input type="hidden" name="selectedDate" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" />

                                    <button type="button" class="option-btn option-btn-danger show-popup" title="Delete task">🗑</button>

                                    @* Popup за потвърждение *@
                                    <div class="delete-popup">
                                        <span>Delete task?</span>
                                        <div class="popup-actions">
                                            <button type="submit" class="popup-btn popup-btn-danger">Yes</button>
                                            <button type="button" class="popup-btn popup-btn-cancel cancel-btn">No</button>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                    @* Детайли и панел с подзадачи (reuse от MyTasks) *@
                    <div class="calendar-subtasks-panel-wrap">
                        <div class="calendar-task-description-details">
                            <button type="button"
                                    class="calendar-description-toggle"
                                    aria-expanded="false">
                                Description
                            </button>

                            <div class="calendar-task-description-panel">
                                <div class="day-task-description calendar-inline-editable"
                                     data-calendar-field="description"
                                     contenteditable="true"
                                     spellcheck="false">
                                    @(string.IsNullOrWhiteSpace(task.Description) ? "Task description" : task.Description)
                                </div>
                            </div>
                        </div>

                        <partial name="~/Views/MyTasks/_TaskSubTasksPanel.cshtml" model="taskItem" />
                    </div>

                    @* Скрита форма за update (използва се при inline редакция) *@
                    <form asp-action="UpdateTask" method="post" class="calendar-task-update-form">
                        <input type="hidden" name="Id" value="@task.Id" />
                        <input type="hidden" name="Title" value="@task.Title" />
                        <input type="hidden" name="Description" value="@task.Description" />
                        <input type="hidden" name="DueDate" value="@task.DueDate.ToString("yyyy-MM-ddTHH:mm")" />
                        <input type="hidden" name="Priority" value="@((int)task.Priority)" />
                        <input type="hidden" name="year" value="@Model.Year" />
                        <input type="hidden" name="month" value="@Model.Month" />
                        <input type="hidden" name="selectedDate" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" />
                    </form>
                </div>
            }
        }
        else
        {
            @* Ако няма задачи за деня *@
            <p class="day-tasks-empty">No tasks for this day.</p>
        }
    </div>

    @* Floating бутон за създаване на нова задача *@
    <form asp-action="CreateTask" method="post" class="calendar-create-task-form">
        <input type="hidden" name="year" value="@Model.Year" />
        <input type="hidden" name="month" value="@Model.Month" />
        <input type="hidden" name="selectedDate" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" />
        <button type="submit" class="calendar-fab" title="Add new task">
            <span class="calendar-fab-plus">+</span>
        </button>
    </form>
</div>
