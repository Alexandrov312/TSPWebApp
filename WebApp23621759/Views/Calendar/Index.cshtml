@using WebApp23621759.Enums
@using WebApp23621759.Helpers
@model WebApp23621759.Models.ViewModel.CalendarViewModel

@{
    var previousMonth = new DateTime(Model.Year, Model.Month, 1).AddMonths(-1);
    var nextMonth = new DateTime(Model.Year, Model.Month, 1).AddMonths(1);
}

<div class="page calendar-page">
    <div class="calendar-layout">
        <div class="calendar-panel">
            <div class="calendar-header">
                <a asp-action="Index"
                   asp-route-year="@previousMonth.Year"
                   asp-route-month="@previousMonth.Month"
                   class="calendar-nav-btn">←</a>

                <h2 class="calendar-title">@Model.MonthName</h2>

                <a asp-action="Index"
                   asp-route-year="@nextMonth.Year"
                   asp-route-month="@nextMonth.Month"
                   class="calendar-nav-btn">→</a>
            </div>

            <div class="calendar-weekdays">
                <div>Mon</div>
                <div>Tue</div>
                <div>Wed</div>
                <div>Thu</div>
                <div>Fri</div>
                <div>Sat</div>
                <div>Sun</div>
            </div>

            <div class="calendar-grid">
                @foreach (var day in Model.Days)
                {
                    <a asp-action="Index"
                       asp-route-year="@Model.Year"
                       asp-route-month="@Model.Month"
                       asp-route-selectedDate="@day.Date.ToString("yyyy-MM-dd")"
                       class="calendar-day @(day.IsCurrentMonth ? "" : "other-month") @(day.IsToday ? "today" : "") @(Model.SelectedDate.Date == day.Date.Date ? "selected" : "")">

                        <span class="day-number">@day.Date.Day</span>

                        @if (day.HasTasks)
                        {
                            <span class="task-dot"></span>
                        }
                    </a>
                }
            </div>
        </div>

        <div class="day-tasks-panel">
            <h3>Tasks for @Model.SelectedDate.ToString("dd.MM.yyyy")</h3>

            <div class="day-tasks-list">
                @if (Model.SelectedDayTasks.Any())
                {
                    @foreach (var task in Model.SelectedDayTasks)
                    {
                        <div class="day-task-card @StatusHelper.GetCalendarCardClass(task.Status) @PriorityHelper.GetCalendarBorderClass(task.Priority)">
                            <div class="day-task-top">
                                <div class="day-task-time">@task.DueDate.ToString("HH:mm")</div>
                                <span class="priority-badge @PriorityHelper.GetCssClass(task.Priority)">
                                    @task.Priority
                                </span>
                            </div>

                            <div class="day-task-title">@task.Title</div>

                            @if (!string.IsNullOrWhiteSpace(task.Description))
                            {
                                <div class="day-task-description">@task.Description</div>
                            }

                            <div class="day-task-bottom">
                                <form asp-action="ChangeStatus" method="post" class="status-form">
                                    <input type="hidden" name="taskId" value="@task.Id" />
                                    <input type="hidden" name="year" value="@Model.Year" />
                                    <input type="hidden" name="month" value="@Model.Month" />
                                    <input type="hidden" name="selectedDate" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" />
                                    <input type="hidden" name="title" value="@task.Title" />

                                    <select name="newStatus"
                                            class="status-select"
                                            onchange="this.form.submit()"
                                    @(task.Status == Status.Overdue ? "disabled" : null)>
                                        @foreach (Status status in Enum.GetValues(typeof(Status)))
                                        {
                                            if (status == Status.Overdue)
                                            {
                                                continue;
                                            }

                                            if (status == task.Status)
                                            {
                                                <option value="@((int)status)" selected>@status</option>
                                            }
                                            else
                                            {
                                                <option value="@((int)status)">@status</option>
                                            }
                                        }
                                    </select>
                                </form>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="day-tasks-empty">No tasks for this day.</p>
                }
            </div>
        </div>
    </div>
</div>