@using WebApp23621759.Helpers
@using WebApp23621759.Models.ViewModel.Notifications
@inject WebApp23621759.Services.AppNotificationService AppNotificationService

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Planora</title>
    <script>
        try {
            document.documentElement.dataset.mytasksView = localStorage.getItem("mytasks:viewMode") || "table";
            document.documentElement.dataset.archiveView = localStorage.getItem("archive:viewMode") || "table";
            document.documentElement.dataset.theme = localStorage.getItem("site:theme") || "light";
        } catch {
            document.documentElement.dataset.mytasksView = "table";
            document.documentElement.dataset.archiveView = "table";
            document.documentElement.dataset.theme = "light";
        }
    </script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet" href="~/css/base/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/base/typography.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/css/components/forms.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/buttons.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/cards.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/badges.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/selectors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/popups.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/tables.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/subtasks.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/css/pages/tasks.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/auth.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/calendar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/create-task.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/notifications.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/WebApp23621759.styles.css" asp-append-version="true" />
</head>
<body>
    <partial name="_Notifications" />

    <div id="notification-container" class="notification-container"></div>
    <div id="toast-container"></div>

    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Planora</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="CreateTask" asp-action="Index">Create Task</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="MyTasks" asp-action="Index">My Tasks</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Calendar" asp-action="Index">Calendar</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Archive" asp-action="Index">Archive</a>
                        </li>
                    </ul>

                    <ul class="navbar-nav ms-auto">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            var currentUserId = UserHelper.GetUserId(User);
                            var notificationModel = new NotificationBellViewModel
                            {
                                UnreadCount = AppNotificationService.GetUnreadCount(currentUserId),
                                Notifications = AppNotificationService.GetLatestUnreadNotifications(currentUserId)
                            };

                            <li class="nav-item d-flex align-items-center me-2">
                                <partial name="~/Views/Notification/_NotificationBell.cshtml" model="notificationModel" />
                            </li>
                        }

                        <li class="nav-item d-flex align-items-center me-2">
                            <button type="button"
                                    class="theme-toggle-btn"
                                    data-theme-toggle
                                    aria-label="Toggle dark mode">
                                <span class="theme-toggle-icon" data-theme-icon aria-hidden="true"></span>
                                <span class="theme-toggle-text" data-theme-text aria-hidden="true"></span>
                            </button>
                            <script>
                                (function () {
                                    const button = document.currentScript.previousElementSibling;
                                    if (!button) {
                                        return;
                                    }

                                    const isDark = document.documentElement.dataset.theme === "dark";
                                    const icon = button.querySelector("[data-theme-icon]");
                                    const text = button.querySelector("[data-theme-text]");
                                    if (icon) {
                                        icon.textContent = isDark ? "\u2600\uFE0F" : "\uD83C\uDF19";
                                    }
                                    if (text) {
                                        text.textContent = isDark ? "Light" : "Dark";
                                    }
                                })();
                            </script>
                        </li>

                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item d-flex align-items-center me-2">
                                <a class="nav-link text-dark nav-user-greeting"
                                   asp-controller="AccountSecurity"
                                   asp-action="Profile">
                                    Hello, @User.Identity.Name
                                </a>
                            </li>

                            <li class="nav-item">
                                <form asp-controller="Login" asp-action="Logout" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-link nav-link text-dark nav-auth-action">
                                        Logout
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark nav-auth-action" asp-controller="Login" asp-action="Index">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark nav-auth-action" asp-controller="Register" asp-action="Index">Register</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
