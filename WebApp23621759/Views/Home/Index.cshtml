@{
    ViewData["Title"] = "Home";
}

<div class="Planora-home">
    <section class="Planora-home-hero">
        <div class="Planora-home-copy">
            <p class="Planora-home-eyebrow">TASK MANAGEMENT MADE SIMPLE</p>
            <h1>Organize your tasks, subtasks and deadlines in one clear workspace.</h1>
            <p class="Planora-home-lead">
                This app helps you plan your work step by step, keep track of dependencies between subtasks,
                follow your progress in different views and get reminders before important deadlines are missed.
            </p>
        </div>

        <div class="Planora-home-panel">
            <div class="Planora-feature-card">
                <strong>Plan your work</strong>
                <span>Create main tasks, split them into subtasks and connect related work.</span>
            </div>
            <div class="Planora-feature-card">
                <strong>Track progress easily</strong>
                <span>Switch between table, grid, calendar and Kanban views.</span>
            </div>
            <div class="Planora-feature-card compact">
                <strong>Never miss a deadline</strong>
                <span>Receive reminders for upcoming and overdue tasks.</span>
            </div>
        </div>
    </section>
</div>